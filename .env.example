# Copy this file to `.env` and fill in real values.
# Never commit `.env` or any file containing real credentials.
# All values are PLACEHOLDERS — replace before using in any environment.

# =============================================================================
# Backend (ElevatorAds.Api) — read by ASP.NET Core configuration provider
# =============================================================================

# ASP.NET Core runtime
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

# PostgreSQL connection string. Use NEON's pooled connection string in
# production. The default below matches the local docker-compose setup.
ConnectionStrings__Default=Host=localhost;Port=5432;Database=elevator_ads;Username=elevator_ads;Password=elevator_ads

# CORS — comma-separated list of allowed frontend origins, no trailing slash
Cors__AllowedOrigins=https://admin.example.com

# JWT — minimum 32 bytes for HS256. Generate with:
#   openssl rand -base64 48
Jwt__Issuer=ElevatorAds
Jwt__Audience=ElevatorAds.Clients
JWT__Secret=replace-me-with-a-32-byte-or-longer-random-secret

# Seed admin user (optional, only used on first startup)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=replace-me
SEED_OPERATOR_PASSWORD=replace-me
SEED_VIEWER_PASSWORD=replace-me

# =============================================================================
# Frontend (elevator-ads-admin) — read at build time by Next.js
# =============================================================================

# Base URL of the backend API, including scheme, no trailing slash.
# Used by the API client and by Next.js rewrites.
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
